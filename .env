# ================== Hugging Face ==================
#HF_TOKEN=your_huggingface_token_here
#HF_USERNAME=your_huggingface_username

# ================== Project Paths ==================
DATA_DIR=./data
PROCESSED_DATA_DIR=./data/processed
OUTPUT_DIR=./outputs
MODEL_OUTPUT_DIR=./outputs/models
LOG_DIR=./logs

# ================== Training Settings ==================
TRAIN_BATCH_SIZE=8
EVAL_BATCH_SIZE=16
MAX_INPUT_LENGTH=1024
MAX_TARGET_LENGTH=128
LEARNING_RATE=3e-5
NUM_TRAIN_EPOCHS=3

# ================== WandB (Optional but Recommended) ==================
#WANDB_PROJECT=flan-t5-cnn-dailymail-summarization
#WANDB_ENTITY=your_wandb_username
#WANDB_API_KEY=your_wandb_api_key_here

# ================== Model & Dataset ==================
MODEL_NAME=google/flan-t5-base
DATASET_NAME=cnn_dailymail
DATASET_VERSION=3.0.0

# ================== Inference Settings ==================
INFERENCE_MAX_LENGTH=150
INFERENCE_MIN_LENGTH=50
INFERENCE_NUM_BEAMS=4
INFERENCE_LENGTH_PENALTY=2.0

# ================== Deployment (Future Use) ==================
API_HOST=0.0.0.0
API_PORT=8000
MODEL_CACHE_DIR=/app/models